{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NWarila/chiseled-application-template/contracts/image-manifest.schema.json",
  "title": "Chiseled application image manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "image",
    "builder",
    "chisel",
    "application",
    "runtime",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ubuntu_series", "platforms"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ubuntu_series": {
          "type": "string",
          "pattern": "^[0-9]{2}\\.[0-9]{2}$"
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^linux/(amd64|arm64)$"
          },
          "uniqueItems": true
        }
      }
    },
    "builder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": {
          "type": "string",
          "pattern": "^.+@sha256:[a-f0-9]{64}$"
        }
      }
    },
    "chisel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cli", "release", "slices"],
      "properties": {
        "cli": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "sha384"],
          "properties": {
            "version": {
              "type": "string",
              "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
            },
            "sha384": {
              "type": "object",
              "additionalProperties": false,
              "minProperties": 1,
              "properties": {
                "amd64": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{96}$"
                },
                "arm64": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{96}$"
                }
              }
            }
          }
        },
        "release": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "commit", "path"],
          "properties": {
            "repository": {
              "const": "https://github.com/canonical/chisel-releases.git"
            },
            "commit": {
              "type": "string",
              "pattern": "^[a-f0-9]{40}$"
            },
            "path": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "slices": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9.+-]+_[a-z0-9.+-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "binary_path", "artifacts", "verification"],
      "allOf": [
        {
          "if": {
            "required": ["source"],
            "properties": { "source": { "const": "vendor-release-binary" } }
          },
          "then": { "required": ["name", "version"] }
        }
      ],
      "properties": {
        "source": {
          "enum": ["go-binary", "vendor-release-binary", "static-binary", "other"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "binary_path": {
          "type": "string",
          "pattern": "^/.+"
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["platform", "path", "sha256"],
            "properties": {
              "platform": {
                "type": "string",
                "pattern": "^linux/(amd64|arm64)$"
              },
              "path": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[^/].*",
                "not": {
                  "anyOf": [
                    {
                      "pattern": "(^|/)\\.\\.(/|$)"
                    },
                    {
                      "pattern": "/$"
                    }
                  ]
                }
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          }
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "enum": ["checksum", "checksum-signature", "sigstore-bundle", "pgp-signature", "none"]
            },
            "checksum_url": {
              "type": "string"
            },
            "signature_url": {
              "type": "string"
            },
            "public_key_url": {
              "type": "string"
            },
            "certificate_identity": {
              "type": "string"
            },
            "certificate_oidc_issuer": {
              "type": "string"
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user", "entrypoint", "forbidden_executables"],
      "properties": {
        "user": {
          "type": "string",
          "not": {
            "enum": ["", "0", "0:0", "root"]
          }
        },
        "entrypoint": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "forbidden_executables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^/.+"
          },
          "uniqueItems": true
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "buildkit-sbom",
              "buildkit-provenance",
              "github-artifact-attestation",
              "cosign-signature",
              "runtime-hardening"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
