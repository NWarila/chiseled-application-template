{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  // Renovate config for NWarila/chiseled-application-template. Keep Actions
  // pinned by digest and surface Chisel-related pins for review in downstreams.
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],

  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",

  "enabledManagers": [
    "github-actions",
    "custom.regex"
  ],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.ya?ml$/",
        "/^docs/.*\\.md$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?\\s+\\w+(?:_VERSION)?:\\s*\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/",
        "/^tools/build_app\\.sh$/",
        "/^\\.github/workflows/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>docker) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\s+GO_IMAGE\\s*\\?=\\s*golang:(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})",
        "# renovate: datasource=(?<datasource>docker) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\s+GO_IMAGE=\"\\$\\{GO_IMAGE:-golang:(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})\\}\"",
        "# renovate: datasource=(?<datasource>docker) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\s+GO_IMAGE:\\s*golang:(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})",
        // reusable-chisel-image-build.yaml carries the canonical default Go
        // builder pin as a workflow_call input default; match its `default:`
        // form so Renovate bumps the reusable alongside Makefile/build_app.sh.
        "# renovate: datasource=(?<datasource>docker) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\s+default:\\s*\"golang:(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})\""
      ]
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    },
    {
      "matchDepNames": ["actions/checkout"],
      "groupName": "actions/checkout",
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    },
    {
      "matchDepNames": ["actions/setup-python"],
      "groupName": "actions/setup-python",
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    },
    {
      "matchDatasources": ["docker"],
      "matchDepNames": ["golang"],
      "groupName": "golang build image",
      "semanticCommitType": "deps",
      "semanticCommitScope": "deps"
    }
  ]
}
